                  (line
                    (vertex
                      (pt -1219000 1219000
                        (width 20000)
                      )
                      (pt -1219000 0
                        (width 20000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt -1219000 1219000
                        (width 10000)
                      )
                      (pt 0 1219000
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
