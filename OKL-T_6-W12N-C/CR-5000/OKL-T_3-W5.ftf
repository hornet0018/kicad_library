                (geometry
                  (line
                    (vertex
                      (pt 0 1219000
                        (width 20000)
                      )
                      (pt -1219000 1219000
                        (width 20000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Assembly-Top)
              (line
